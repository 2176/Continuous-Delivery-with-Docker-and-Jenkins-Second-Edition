pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            steps {
                dir('Chapter07/sample5') {
                    sh 'chmod +x gradlew'

                    script {
                        int result = sh(
                            script: './gradlew --no-daemon clean test',
                            returnStatus: true
                        )

                        if (result == 0) {
                            echo 'tests pass!'
                        } else {
                            echo 'tests fail!'
                            currentBuild.result = 'FAILURE'
                        }
                    }
                }
            }

            post {
                always {
                    junit allowEmptyResults: true, testResults: 'Chapter07/sample5/build/test-results/test/*.xml'
                }
            }
        }

        stage('Code Coverage') {
            when {
                branch 'master'
            }

            steps {
                dir('Chapter07/sample5') {
                    writeFile file: 'force-jacoco.gradle', text: '''
allprojects {
    afterEvaluate {
        plugins.withId('jacoco') {
            jacoco {
                toolVersion = '0.8.12'
            }
        }
    }
}
'''
                    sh './gradlew --no-daemon jacocoTestReport -I force-jacoco.gradle || true'
                }
            }

            post {
                always {
                    archiveArtifacts allowEmptyArchive: true, artifacts: 'Chapter07/sample5/build/reports/jacoco/**'
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts allowEmptyArchive: true, artifacts: 'Chapter07/sample5/build/reports/tests/**'
        }
    }
}
