stage('Test') {
    steps {
        dir('Chapter07/sample5') {
            writeFile file: 'disable-jacoco.gradle', text: '''
allprojects {
    afterEvaluate {
        tasks.withType(org.gradle.api.tasks.testing.Test) { testTask ->
            if (testTask.extensions.findByName("jacoco") != null) {
                testTask.jacoco.enabled = false
            }
            testTask.jvmArgs = testTask.jvmArgs.findAll { arg ->
                !arg.toString().contains("jacoco")
            }
        }
    }
}
'''
            sh 'chmod +x gradlew'
            sh './gradlew --no-daemon clean test -I disable-jacoco.gradle'
        }
    }
}
