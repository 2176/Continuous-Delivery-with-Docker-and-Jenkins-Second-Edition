pipeline {
    agent { label 'docker-agent' }

    stages {
        stage('Show branch info') {
            steps {
                echo "BRANCH_NAME=${env.BRANCH_NAME}"
                echo "CHANGE_BRANCH=${env.CHANGE_BRANCH}"
                echo "CHANGE_TARGET=${env.CHANGE_TARGET}"
            }
        }

        stage('Validate branch') {
            steps {
                script {
                    def branchName = env.CHANGE_BRANCH ?: env.BRANCH_NAME
                    def targetBranch = env.CHANGE_TARGET ?: ''

                    if (branchName == 'main' || branchName == 'master' || targetBranch == 'main' || targetBranch == 'master') {
                        echo 'main/master branch or pull request to main/master detected'
                    } else if (branchName.contains('feature')) {
                        echo 'feature branch detected'
                    } else {
                        error "Invalid branch: ${branchName}. Branch must be main/master or contain feature."
                    }
                }
            }
        }

        stage('Unit tests') {
            steps {
                echo 'Running unit tests'
                dir('Chapter08/sample1') {
                    sh './gradlew test'
                }
            }
        }

        stage('Checkstyle') {
            when {
                expression {
                    def branchName = env.CHANGE_BRANCH ?: env.BRANCH_NAME
                    return branchName.contains('feature')
                }
            }
            steps {
                echo 'Running Checkstyle on feature branch'
                dir('Chapter08/sample1') {
                    sh './gradlew checkstyleMain checkstyleTest'
                }
            }
        }

        stage('CodeCoverage') {
            when {
                expression {
                    return env.BRANCH_NAME == 'main' || env.BRANCH_NAME == 'master' || env.CHANGE_TARGET == 'main' || env.CHANGE_TARGET == 'master'
                }
            }
            steps {
                echo 'Running CodeCoverage on main/master branch'
                dir('Chapter08/sample1') {
                    sh './gradlew jacocoTestReport jacocoTestCoverageVerification'
                }
            }
        }
    }

    post {
        success {
            echo 'pipeline ran perfectly'
        }
        failure {
            echo 'pipeline failure'
        }
    }
}